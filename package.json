{
  "name": "slotmerge",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.13.1",
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "format:check": "prettier --check \"app/**/*.{ts,tsx}\" \"src/**/*.ts\" \"scripts/**/*.ts\" \"docs/local-stack.md\" package.json tsconfig.json vitest.config.ts drizzle.config.ts next.config.ts eslint.config.mjs docker-compose.yml \".github/workflows/*.yml\"",
    "lint": "eslint .",
    "build": "next build",
    "dev:web": "next dev -H 0.0.0.0",
    "dev:worker": "tsx src/worker/run.ts",
    "db:migrate": "drizzle-kit migrate",
    "local:up": "docker compose up --build",
    "local:verify": "tsx scripts/local-verify.ts"
  },
  "dependencies": {
    "drizzle-orm": "^0.44.2",
    "next": "^15.3.5",
    "nodemailer": "^6.10.1",
    "graphile-worker": "^0.16.6",
    "pg": "^8.16.3",
    "pino": "^9.7.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tsx": "^4.20.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@next/eslint-plugin-next": "^15.3.5",
    "@types/node": "^24.0.10",
    "@types/nodemailer": "^6.4.17",
    "@types/pg": "^8.15.4",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "drizzle-kit": "^0.31.4",
    "eslint": "^9.30.1",
    "eslint-config-next": "^15.3.5",
    "prettier": "^3.6.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.36.0",
    "vitest": "^3.2.4"
  }
}
