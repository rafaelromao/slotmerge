#!/usr/bin/env bash
# Blocks any commit that adds/modifies/contains paths under `.sandman/`.
# Reason: the Sandman worktree's `task.md`, `config.yaml`, `events.jsonl`,
# `batches/`, `reviews/`, etc. are runtime state, not source. They must
# never enter a branch's history. `.gitignore` already ignores untracked
# paths, but agents have historically used `git add -f` to bypass ignore,
# which re-tracked `.sandman/task.md` historically.
#
# Install one of two ways:
#   cp scripts/hooks/pre-commit .git/hooks/pre-commit
# or
#   git config core.hooksPath scripts/hooks
set -euo pipefail

if git diff --cached --name-only --diff-filter=ACMR | grep -E '(^|/)(\.sandman/|\.sandman$)' >/dev/null; then
  echo "pre-commit: refusing to commit changes under \`.sandman/\`." >&2
  echo "  These paths are Sandman runtime state and must never enter git." >&2
  echo "  Unstage them with:  git restore --staged .sandman/" >&2
  echo "  Tracked offenders:" >&2
  git diff --cached --name-only --diff-filter=ACMR | grep -E '(^|/)(\.sandman/|\.sandman$)' | sed 's/^/    /' >&2
  exit 1
fi
